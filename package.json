{
  "name": "natsu",
  "version": "0.1.0",
  "private": true,
  "description": "NATSU Cross-Platform Voice AI (Web + Mobile + Desktop)",
  "main": "dist/electron/main.js",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
