  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "@capacitor/cli": "^7.0.0",
    "@types/electron": "^34.0.0"
